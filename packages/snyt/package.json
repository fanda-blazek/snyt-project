{
  "name": "snyt",
  "version": "0.0.0",
  "description": "Headless UI primitives built on native Custom Elements.",
  "keywords": [
    "custom-elements",
    "headless-ui",
    "ui-primitives",
    "web-components"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./define": {
      "types": "./dist/define.d.mts",
      "default": "./dist/define.mjs"
    },
    "./dialog": {
      "types": "./dist/dialog.d.mts",
      "default": "./dist/dialog.mjs"
    },
    "./dialog/define": {
      "types": "./dist/dialog/define.d.mts",
      "default": "./dist/dialog/define.mjs"
    },
    "./toggle": {
      "types": "./dist/toggle.d.mts",
      "default": "./dist/toggle.mjs"
    },
    "./toggle/define": {
      "types": "./dist/toggle/define.d.mts",
      "default": "./dist/toggle/define.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "default": "./dist/types.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  }
}
